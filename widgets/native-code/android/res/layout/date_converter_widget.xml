<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/widget_accent_dot"
            android:contentDescription="@null"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="DATE CONVERTER"
            android:textSize="10sp"
            android:textColor="#FF808080"
            android:textStyle="bold"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/today_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY"
            android:textSize="9sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:paddingLeft="7dp"
            android:paddingRight="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/widget_pill_red" />
    </LinearLayout>

    <!-- AD stepper -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/prev_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="‹"
            android:textSize="18sp"
            android:textColor="#FF000000"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/widget_chip_outline" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AD"
                android:textSize="9sp"
                android:textColor="#FF808080" />

            <TextView
                android:id="@+id/ad_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="14sp"
                android:textColor="#FF000000"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/next_button"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:text="›"
            android:textSize="18sp"
            android:textColor="#FF000000"
            android:textStyle="bold"
            android:gravity="center"
            android:background="@drawable/widget_chip_outline" />
    </LinearLayout>

    <!-- BS result -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BS"
            android:textSize="9sp"
            android:textColor="#FF808080"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/bs_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="—"
            android:textSize="16sp"
            android:textColor="#FFD71921"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/open_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="OPEN CONVERTER"
        android:textSize="9sp"
        android:textColor="#FF000000"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_chip_outline" />

</LinearLayout>
