<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="TODAY"
        android:textSize="11sp"
        android:textColor="#888888"
        android:letterSpacing="0.2"
        android:layout_marginBottom="16dp" />

    <!-- BS Date (Large) -->
    <TextView
        android:id="@+id/bs_date_large"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2082/9/24"
        android:textSize="36sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- BS Date (Nepali/Descriptive) -->
    <TextView
        android:id="@+id/bs_date_nepali"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="पौष २४, २०८२"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="16dp" />

    <!-- AD Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AD: "
            android:textSize="13sp"
            android:textColor="#999999" />
        
        <TextView
            android:id="@+id/ad_date_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="January 08, 2026"
            android:textSize="13sp"
            android:textColor="#333333" />
    </LinearLayout>

    <!-- Tithi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tithi: "
            android:textSize="13sp"
            android:textColor="#999999" />
        
        <TextView
            android:id="@+id/tithi_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="शुक्ल पक्ष अष्टमी"
            android:textSize="13sp"
            android:textColor="#333333"
            android:textStyle="italic" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginVertical="12dp" />

    <!-- Sunrise/Sunset -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunrise"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginBottom="2dp" />
            
            <TextView
                android:id="@+id/sunrise_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="06:45 AM"
                android:textSize="16sp"
                android:textColor="#FF6B00"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="end">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sunset"
                android:textSize="11sp"
                android:textColor="#999999"
                android:layout_marginBottom="2dp" />
            
            <TextView
                android:id="@+id/sunset_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="05:30 PM"
                android:textSize="16sp"
                android:textColor="#4A4A4A"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
