<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_metals"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <View
            android:layout_width="3dp"
            android:layout_height="14dp"
            android:background="#FFD700"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="METAL PRICES"
            android:textSize="10sp"
            android:textColor="#F5E6A8"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.28" />

        <TextView
            android:id="@+id/updated_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="9sp"
            android:textColor="#9A8E5A"
            android:letterSpacing="0.1" />
    </LinearLayout>

    <!-- Gold card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/widget_metal_gold_card"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="@drawable/widget_metal_coin_gold">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Au"
                android:textColor="#3D2E00"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GOLD · per Tola"
                android:textSize="9sp"
                android:textColor="#C8B872"
                android:letterSpacing="0.22" />

            <TextView
                android:id="@+id/gold_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:textColor="#FFD700"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </LinearLayout>
    </LinearLayout>

    <!-- Silver card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/widget_metal_silver_card">

        <LinearLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:background="@drawable/widget_metal_coin_silver">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ag"
                android:textColor="#1F1F26"
                android:textSize="14sp"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SILVER · per Tola"
                android:textSize="9sp"
                android:textColor="#9CA0AD"
                android:letterSpacing="0.22" />

            <TextView
                android:id="@+id/silver_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="20sp"
                android:textColor="#E5E7EB"
                android:textStyle="bold"
                android:fontFamily="serif" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
