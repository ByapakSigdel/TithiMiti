<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Top row: weekday pill + AD date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/weekday_pill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TODAY"
            android:textSize="9sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:paddingLeft="7dp"
            android:paddingRight="7dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="@drawable/widget_pill_red" />

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/ad_date_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="11sp"
            android:textColor="#FF808080" />
    </LinearLayout>

    <!-- Hero BS Date -->
    <TextView
        android:id="@+id/bs_date_large"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="—"
        android:textSize="24sp"
        android:textColor="#FF000000"
        android:textStyle="bold"
        android:layout_marginTop="6dp" />

    <TextView
        android:id="@+id/bs_date_nepali"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#FF808080" />

    <!-- Tithi -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="6dp">

        <ImageView
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:src="@drawable/widget_accent_dot"
            android:contentDescription="@null"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/tithi_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="—"
            android:textSize="12sp"
            android:textColor="#FF000000" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#FFE0E0E0"
        android:contentDescription="@null"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <!-- Sunrise / Sunset compact row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SUNRISE"
            android:textSize="9sp"
            android:textColor="#FF808080" />

        <TextView
            android:id="@+id/sunrise_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:textStyle="bold"
            android:layout_marginEnd="14dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUNSET"
            android:textSize="9sp"
            android:textColor="#FF808080"
            android:layout_marginEnd="6dp" />

        <TextView
            android:id="@+id/sunset_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--:--"
            android:textSize="12sp"
            android:textColor="#FF000000"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Today's event (single line) -->
    <TextView
        android:id="@+id/today_event_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No event today"
        android:textSize="11sp"
        android:textColor="#FF808080"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="6dp" />

</LinearLayout>
